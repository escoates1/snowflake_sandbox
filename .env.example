# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Snowflake account identifier.
# Find it in Snowsight > Admin > Accounts. Format: orgname-accountname
SNOWFLAKE_ACCOUNT=orgname-accountname

SNOWFLAKE_USER=your_username

# Used only during initial setup (setup_snowflake.py) before key-pair auth is configured.
# Remove or leave blank once key-pair auth is set up.
SNOWFLAKE_PASSWORD=your_password

# Path to your RSA private key file (generated during key-pair setup).
SNOWFLAKE_PRIVATE_KEY_PATH=rsa_key.p8

SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# dbt target: dev or prod
DBT_TARGET=dev
